# Copy this file to .env and fill in values from the Discord Developer Portal.
# Do not commit .env — it is gitignored.

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: guild snowflake for dev-only slash deploy (pnpm deploy)
DISCORD_GUILD_ID=
PREFIX=!
# Optional: Prometheus scrape endpoint (e.g. 9090 → http://127.0.0.1:9090/metrics)
METRICS_PORT=
# SQLite file is created at ./data/stratum.db (see main.ts)
