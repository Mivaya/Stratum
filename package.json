{
  "name": "stratum",
  "version": "0.1.0",
  "private": true,
  "description": "Native Discord bot framework for Node.js and TypeScript — Sapphire-style pieces on @stratum/rest + @stratum/gateway; Vault, Sequences, tier split, and metrics built in.",
  "author": "Interittus13 <arpit.gupta.0121@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Interittus13/Stratum#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Interittus13/Stratum.git"
  },
  "bugs": {
    "url": "https://github.com/Interittus13/Stratum/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "bot-framework",
    "typescript",
    "stratum",
    "sapphire",
    "gateway",
    "sharding",
    "rest-api",
    "tier-split",
    "vault",
    "sequences",
    "metrics"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r run typecheck",
    "demo": "pnpm --filter @stratum/example-bot demo",
    "example:bot": "pnpm --filter @stratum/example-bot start",
    "docs:dev": "pnpm --filter @stratum/docs dev",
    "docs:build": "pnpm --filter @stratum/docs build",
    "docs:preview": "pnpm --filter @stratum/docs preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
