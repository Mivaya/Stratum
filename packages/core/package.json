{
  "name": "@stambha/core",
  "version": "0.1.0",
  "description": "Transport-agnostic Discord bot core — client, pipeline, registries, sequences, chron, and tier split (no discord.js or Discordeno)",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/mivaya/Stambha/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivaya/Stambha.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/mivaya/Stambha/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "bot-framework",
    "typescript",
    "stambha"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@stambha/runtime": "workspace:*",
    "cron-parser": "^5.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
