{
  "name": "@stambha/gateway",
  "version": "0.2.2",
  "description": "Gateway shard manager, resharding, worker bus, GatewayEventHub, and native Stambha routing",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/mivaya/Stambha/tree/main/packages/gateway#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivaya/Stambha.git",
    "directory": "packages/gateway"
  },
  "bugs": {
    "url": "https://github.com/mivaya/Stambha/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "stambha",
    "gateway",
    "sharding"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@stambha/core": "workspace:*",
    "@stambha/transport": "workspace:*",
    "@stambha/transform": "workspace:*"
  },
  "dependencies": {
    "@stambha/transform": "workspace:*"
  },
  "devDependencies": {
    "@stambha/core": "workspace:*",
    "@stambha/transform": "workspace:*",
    "@stambha/transport": "workspace:*",
    "@types/node": "^22.13.4",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
