{
  "name": "@stambha/loader",
  "version": "0.2.2",
  "description": "Auto-load Stambha pieces from Sapphire/Klasa-style folders (commands, listeners, scouts, etc.)",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/mivaya/Stambha/tree/main/packages/loader#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivaya/Stambha.git",
    "directory": "packages/loader"
  },
  "bugs": {
    "url": "https://github.com/mivaya/Stambha/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "stambha",
    "loader",
    "sapphire",
    "klasa"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@stambha/core": "workspace:*"
  },
  "dependencies": {
    "@stambha/runtime": "workspace:*"
  },
  "devDependencies": {
    "@stambha/core": "workspace:*",
    "@types/node": "^22.13.4",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
