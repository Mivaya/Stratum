  },
  "peerDependencies": {
    "@stambha/core": "workspace:*"
  },
  "devDependencies": {
    "@stambha/core": "workspace:*",
    "@types/node": "^22.13.4",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
