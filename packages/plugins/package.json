{
  "name": "@stambha/plugins",
  "version": "0.2.1",
  "description": "Stambha plugin lifecycle hooks and container (definePlugin, StambhaContainer)",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/mivaya/Stambha/tree/main/packages/plugins#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivaya/Stambha.git",
    "directory": "packages/plugins"
  },
  "bugs": {
    "url": "https://github.com/mivaya/Stambha/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "stambha",
    "plugins",
    "container",
    "sapphire"
