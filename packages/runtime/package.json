{
  "name": "@stambha/runtime",
  "version": "0.2.1",
  "description": "Cross-runtime abstractions for Stambha — Node.js, Bun, and Deno",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/mivaya/Stambha/tree/main/packages/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivaya/Stambha.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/mivaya/Stambha/issues"
  },
  "keywords": ["discord", "discord-bot", "stambha", "deno", "bun", "runtime"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "deno": "./dist/index.js",
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node dist/smoke.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.3.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
